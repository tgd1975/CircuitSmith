# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtualenv
.venv/
venv/
env/

# Build artefacts
build/
dist/
*.egg

# IDE / editor
.idea/
.vscode/launch.json
.vscode/c_cpp_properties.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local Claude settings (user-specific permissions)
.claude/settings.local.json
.claude/*.lock

# Security-review report — regenerated by git hooks on every pull/merge/rebase
.claude/security-review-latest.md

# direnv local env (per-developer paths, ports, MACs — see .envrc.example)
.envrc

# Housekeep single-instance lock
.housekeep.lock

# Personal-data patterns used by the security-review hook (TASK-074).
# The real patterns are personal-data themselves (your literal email
# address) — they would defeat their own purpose if committed. The
# .example file documents the format; the local file is loaded at hook
# runtime if present.
scripts/git-hooks/personal_data_patterns.yml

# Secrets (never commit)
.env
.env.local
*.key
*.pem
