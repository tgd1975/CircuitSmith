{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://circuitsmith.dev/schemas/circuit.schema.json",
  "title": "Circuit description (.circuit.yml)",
  "description": "Structural schema for the three top-level sections (meta, components, connections). The allowed component-type values and pin-reference validity are derived from components/*.py at validation time and enforced by the post-schema validator (S4, S5). Format reference: idea-001.yaml-format.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "components", "connections"],
  "properties": {
    "meta":        { "$ref": "#/$defs/meta" },
    "components":  { "$ref": "#/$defs/components" },
    "connections": { "$ref": "#/$defs/connections" },
    "sub-blocks":  { "$ref": "#/$defs/subBlocks" },
    "instances":   { "$ref": "#/$defs/instances" }
  },

  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title", "target"],
      "properties": {
        "title":   { "type": "string", "minLength": 1 },
        "target":  { "type": "string", "minLength": 1 },
        "config":  { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "erc": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[ES][0-9]+$": { "enum": ["off", "warn", "error"] }
          }
        }
      }
    },

    "components": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": { "$ref": "#/$defs/component" }
      },
      "additionalProperties": false
    },

    "component": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type":  { "type": "string", "pattern": "^[a-z][a-z0-9_]*/[a-z0-9_]+$" },
        "label": { "type": "string" },
        "value": { "type": ["string", "number"] },
        "color": { "type": "string" }
      }
    },

    "connections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/net" }
    },

    "net": {
      "type": "object",
      "required": ["net"],
      "additionalProperties": false,
      "properties": {
        "net": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_+\\-]+$"
        },
        "pins":     { "$ref": "#/$defs/pinList" },
        "path":     { "$ref": "#/$defs/pathList" },
        "bus":      { "type": "boolean" },
        "backbone": { "$ref": "#/$defs/pinList" },
        "taps":     { "$ref": "#/$defs/pinList" },
        "pull":     { "enum": ["firmware", "hardware_up", "hardware_down"] },
        "role":     { "$ref": "#/$defs/role" },
        "segment_names": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "oneOf": [
        {
          "required": ["pins"],
          "not": { "anyOf": [
            { "required": ["path"] },
            { "required": ["bus"] },
            { "required": ["backbone"] },
            { "required": ["taps"] }
          ] }
        },
        {
          "required": ["path"],
          "not": { "anyOf": [
            { "required": ["pins"] },
            { "required": ["bus"] },
            { "required": ["backbone"] },
            { "required": ["taps"] }
          ] }
        },
        {
          "required": ["bus", "backbone"],
          "not": { "anyOf": [
            { "required": ["pins"] },
            { "required": ["path"] }
          ] },
          "properties": {
            "bus": { "const": true }
          }
        }
      ]
    },

    "pinList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "comment": "REF.PIN where REF matches the components key pattern and PIN is any non-empty token of [A-Za-z0-9_+\\-/].",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z0-9_+\\-/]+$"
      }
    },

    "pathList": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "comment": "Either a REF.PIN pin token or a bare net-name. The post-schema validator decides which.",
        "pattern": "^([A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z0-9_+\\-/]+|[A-Za-z0-9_+\\-]+)$"
      }
    },

    "role": {
      "oneOf": [
        { "enum": ["in", "out", "bidir"] },
        {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z0-9_+\\-/]+$": {
              "enum": ["in", "out", "bidir"]
            }
          },
          "additionalProperties": false
        }
      ]
    },

    "subBlocks": {
      "type": "object",
      "comment": "EPIC-014 / TASK-115. Map of sub-block definitions. Each entry is reusable inside `instances:` (one or more times). Sub-blocks compose components + an internal connections grammar identical to the top-level form; their ports surface to top-level as named-port references (`<instance>.<port>`). Nested sub-blocks are rejected by the post-schema validator (S6); JSON Schema does not express the cross-reference itself.",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": { "$ref": "#/$defs/subBlock" }
      },
      "additionalProperties": false
    },

    "subBlock": {
      "type": "object",
      "required": ["components", "ports"],
      "additionalProperties": false,
      "properties": {
        "components":  { "$ref": "#/$defs/components" },
        "ports":       { "$ref": "#/$defs/ports" },
        "connections": { "$ref": "#/$defs/connections" }
      }
    },

    "ports": {
      "type": "object",
      "comment": "Named-port map per EPIC-014 frozen decision: ports: { signal_in: R.1, gnd: C.2 }. Each value is a sub-block-internal REF.PIN reference.",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z0-9_+\\-/]+$"
        }
      },
      "additionalProperties": false
    },

    "instances": {
      "type": "object",
      "comment": "EPIC-014 / TASK-115. Map of sub-block instantiations. Each entry names a sub-block by key; the post-schema validator (S7) rejects entries whose `sub-block:` does not exist in the top-level `sub-blocks:` map.",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": { "$ref": "#/$defs/instance" }
      },
      "additionalProperties": false
    },

    "instance": {
      "type": "object",
      "required": ["sub-block"],
      "additionalProperties": false,
      "properties": {
        "sub-block": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$" }
      }
    }
  }
}
